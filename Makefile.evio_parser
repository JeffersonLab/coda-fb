# Makefile for EVIO6 Event Parser
# Usage: make -f Makefile.evio_parser

CXX = g++
CXXFLAGS = -std=c++17 -O2 -Wall -Wextra
TARGET = evio_event_parser
SRC = evio_event_parser.cpp

all: $(TARGET)

$(TARGET): $(SRC)
	$(CXX) $(CXXFLAGS) $(SRC) -o $(TARGET)

clean:
	rm -f $(TARGET)

test: $(TARGET)
	./$(TARGET) frames_thread0_file0000.evio

test-verbose: $(TARGET)
	./$(TARGET) frames_thread0_file0000.evio --verbose | head -200

.PHONY: all clean test test-verbose
